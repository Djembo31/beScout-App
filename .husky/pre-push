#!/usr/bin/env bash
# BeScout Pre-Push Gate (Slice 248 → überarbeitet 2026-06-23)
#
# WARUM die Überarbeitung (2026-06-23): Die ehemalige `CI=true vitest run`-Zeile
# war für ~30-90s budgetiert (Slice 248), die Suite ist auf ~6-7 min gewachsen
# (3242 Tests). Diese Laufzeit war reproduzierbar der AUSLÖSER für
# "failed to push some refs" (HTTPS-Transport bricht nach dem langen Hook ab;
# `git push --no-verify` landet denselben Commit sofort).
# Verifiziert 2026-06-23: 3× Push-Fail nach 6-min-Hook, 0× Fail ohne Hook.
#
# Architektonischer Layer-Stack (aktuell):
#   pre-commit (Slice 243):  tsc + audit:type-truth + audit:stale +
#                            audit:wiring:check + lint-staged  (~32s)
#   pre-push   (heute):      audit:silent-fail:check  (~5s) — schneller Gate gegen
#                            den häufigsten CI-lint-Fail (Silent-Fail-Baseline-Drift,
#                            war die Quelle der täglichen CI-Fail-Mails). Hält die
#                            Verbindung frisch → Push-Transport bleibt stabil.
#   ci.yml      (post-push): lint + audit + build + test (volle vitest, ~2-3 min)
#                            = AUTORITÄT für Tests/Build (CI-Runner schneller als lokal).
#
# Begründung der Aufteilung (ersetzt Slice-248-Annahme): Die volle Test-Suite läuft
# zuverlässig in CI (test-job grün). Lokal vor dem Push nur die billigen, häufig-
# brechenden Gates — so bleibt der Push schnell + zuverlässig, CI fängt Test-/Build-Drift.
#
# Bypass: git push --no-verify.

set -e

echo "[pre-push] audit:silent-fail:check (schneller Gate gegen Baseline-Drift)..."
pnpm run audit:silent-fail:check

echo "[pre-push] OK — volle Tests laufen in CI (test-job)."
