#!/usr/bin/env bash
# BeScout Pre-Push Gate (Slice 248, 2026-04-28)
# Laeuft vor JEDEM Push — simuliert lokal CI test-job.
#
# Architektonischer Layer-Stack (von Slice 248):
#   pre-commit (Slice 243):  tsc + audit:type-truth + audit:stale +
#                            audit:wiring:check + lint-staged  (~32s)
#   pre-push   (Slice 248):  vitest (CI=true, skip integration)  (~30-90s)
#   ci.yml      (post-push): lint + audit + build + test  (~2-3 min)
#
# Begruendung: Branch-Protection mit enforce_admins=true ist nicht direct-push-
# kompatibel (Slice 244 Phase 2 Catch-22 — Push blockt bis CI gruen, CI braucht
# Push). Solo-Dev-Workflow braucht pre-push-Layer als ECHTE Sicherheit gegen
# silent-CI-Failures (Pattern Slice 226-245 — ≥20 Pushes durchgehend rot
# ohne dass jemand merkt).
#
# Bewusst NICHT in pre-push:
#   - tsc            → bereits in pre-commit (Slice 243)
#   - audit:*        → bereits in pre-commit (Slice 243)
#   - next build     → 5+ min, in CI 2nd-Layer (audit-Job 36s + build-Job)
#   - bundle-budget  → Teil von next build → in CI
#
# Pre-push Test-Layer faengt: Test-Mock-Drift (Slice 247 Pattern), Logic-Bugs
# die tsc nicht catched. Build/Bundle-Drift wird in CI sichtbar (4 required-
# status-checks ab Slice 244 Phase 2).
#
# CI=true env-var: triggert vitest-config skipIntegration → Integration-Tests
# (db-invariants etc.) werden geskippt, Parität mit CI-Verhalten.
#
# Bypass: git push --no-verify (gleiche Mechanik wie pre-commit). Bewusst
# opt-out moeglich; CI fängt es trotzdem als 2nd-Layer.

set -e

echo "[pre-push] vitest run (Test-job-Simulation, CI=true für Integration-Test-Skip-Parität)..."
CI=true pnpm exec vitest run

echo "[pre-push] OK"
