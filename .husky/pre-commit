#!/usr/bin/env bash
# BeScout Pre-Commit Gate (Slice 118, refactored Slice 185, audit-wired Slice 243)
# Laeuft vor JEDEM Commit — schnelle Checks, keine Full-Vitest-Suite.
#
# 1. tsc --noEmit — faengt Type-Bugs frueh (whole project)
# 2. audit:type-truth — D43 Static-Pattern-Detection (~7s, exit 1 bei Risk-Pattern)
# 3. audit:stale — D48 Audit-Stale-Catcher (~7s, exit 1 bei stale row-marker)
# 4. audit:wiring:check — D54 Tool-Wiring-Gate (~7s, exit 1 bei orphan-Tool)
# 5. audit:boundary:check — S4 Source-of-Truth Ratchet (~2s, exit 1 bei neuem Bridge-/Direct-Supabase-Import)
# 6. audit:test-confidence:check — S5 Test-Confidence Ratchet (~2s, exit 1 bei neuem Placeholder/Skip)
# 7. audit:knowledge:check — E0-W2gov Wissens-Integrität (~2s, exit 1 NUR bei HARD: broken-link/orphan/no-frontmatter; Staleness=SOFT→nightly)
# 7b. audit:dup:check — Slice 434 Duplikations-Ratchet (WARN-first, non-blocking via `|| true` bis FP=0; dann BLOCK-Flip)
# 8. lint-staged — ESLint + auto-fix auf staged files (Config: .lintstagedrc.json)
# 9. compliance + i18n-coverage + conflict-marker — Slice 436: aus dem kaputten Claude-Hook
#    pre-commit-guard.sh hierher konsolidiert (EINE autoritative Commit-Gate-Quelle statt zwei).
#
# Bewusst ausgeschlossen: audit:orphan (66s, gehoert pre-push), audit:silent-fail (CI),
# audit:mutation-race (CI). Slice 243 docs/test.rtf #8 strukturell geheilt.

set -e

# [pre-commit] Tracker-Reconcile-Reminder (Slice 354) — NON-BLOCKING.
# Mechanischer Trigger: ein neuer Slice wird geLOGgt (worklog/log.md bekommt ein neues "## NNN |").
# Verhindert die Stale-Tracker-Klasse (348/349 waren in s7-phase3-remaining.md nicht abgehakt,
# weil KEIN Ritual diese Epic-Sub-Tracker anfasst). Surface am richtigen Moment statt Memory.
if git diff --cached --name-only | grep -qx 'worklog/log.md'; then
  NEW_SLICE=$(git diff --cached -U0 -- worklog/log.md 2>/dev/null | grep -E '^\+## [0-9]+ \|' | head -1 | sed 's/^+//')
  if [ -n "$NEW_SLICE" ]; then
    echo ""
    echo "[TRACKER-RECONCILE] Neuer Slice geLOGgt: $NEW_SLICE"
    echo "  → Status-Surfaces auf Ist-Stand? (sonst Stale wie 348/349 im s7-tracker):"
    echo "     • MASTERPLAN.md  (Stand-Satz)"
    echo "     • TODO.md        (Erledigt + P0/P1)"
    echo "     • worklog/s7-phase3-remaining.md  (Epic-Tracker — falls S7-Scope berührt)"
    echo "     • worklog/notes/mock2pro-plan.md  (falls Mock→Pro-Scope betroffen)"
    echo "  Reine Doku/Meta-Slices ohne Domain-Scope: ignorieren."
    echo ""
  fi
fi

# [pre-commit] Tracker-Drift-Guard (Slice 430) — NON-BLOCKING (Script exit 0).
# Flaggt Mega-Zeilen in den scannbaren Trackern (MASTERPLAN/TODO/INDEX/handoff).
# Verhindert das Nachwachsen der „Stand 4-5× dupliziert"-Krankheit (Slice 430).
node scripts/tracker-drift-check.mjs || true

# [pre-commit] Merge-conflict markers in staged files (Slice 436: aus pre-commit-guard.sh konsolidiert).
# `|| true` am Pipe-Ende: grep exit 1 (kein Treffer) darf `set -e` nicht abbrechen.
CONFLICT_FILES="$(git diff --cached --name-only 2>/dev/null | xargs -I{} grep -l '^<<<<<<< ' {} 2>/dev/null | head -5 || true)"
if [ -n "$CONFLICT_FILES" ]; then
  echo "❌ Merge-conflict markers in staged files:"
  echo "$CONFLICT_FILES"
  exit 1
fi

# [pre-commit] Compliance + i18n (Slice 436: aus pre-commit-guard.sh konsolidiert; je <1s, fail-fast vor tsc).
echo "[pre-commit] compliance (business.md wording)..."
bash scripts/audit/compliance.sh

echo "[pre-commit] i18n-coverage (DE<->TR parity)..."
node scripts/audit/i18n-coverage.js

echo "[pre-commit] tsc --noEmit..."
npx tsc --noEmit

echo "[pre-commit] audit:type-truth..."
pnpm run audit:type-truth

echo "[pre-commit] audit:stale..."
pnpm run audit:stale

echo "[pre-commit] audit:wiring:check..."
pnpm run audit:wiring:check

echo "[pre-commit] audit:boundary:check..."
pnpm run audit:boundary:check

echo "[pre-commit] audit:test-confidence:check..."
pnpm run audit:test-confidence:check

echo "[pre-commit] audit:knowledge:check..."
pnpm run audit:knowledge:check

echo "[pre-commit] audit:dup:check (Slice 434 Duplikations-Ratchet, WARN-first/non-blocking)..."
pnpm run audit:dup:check || true

echo "[pre-commit] lint-staged..."
npx lint-staged

echo "[pre-commit] OK"
