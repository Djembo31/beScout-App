#!/usr/bin/env bash
# BeScout Pre-Commit Gate (Slice 118)
# Läuft vor JEDEM Commit — schnelle Checks, keine Full-Vitest-Suite (braucht zu lang).

set -e

# 1. TypeScript — fängt Type-Bugs früh
echo "[pre-commit] tsc --noEmit..."
npx tsc --noEmit

# 2. ESLint auf staged files — fängt Common-Errors
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(ts|tsx|js|jsx|mjs)$" | tr '\n' ' ')
if [ -n "$STAGED_FILES" ]; then
  echo "[pre-commit] ESLint staged..."
  npx eslint --no-error-on-unmatched-pattern $STAGED_FILES
fi

echo "[pre-commit] OK"
