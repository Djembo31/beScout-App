#!/usr/bin/env bash
# BeScout Pre-Commit Gate (Slice 118, refactored Slice 185)
# Laeuft vor JEDEM Commit — schnelle Checks, keine Full-Vitest-Suite.
#
# 1. tsc --noEmit — faengt Type-Bugs frueh (whole project)
# 2. lint-staged — ESLint + auto-fix auf staged files (Config: .lintstagedrc.json)

set -e

echo "[pre-commit] tsc --noEmit..."
npx tsc --noEmit

echo "[pre-commit] lint-staged..."
npx lint-staged

echo "[pre-commit] OK"
