# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-key

# Sentry (optional — error tracking)
NEXT_PUBLIC_SENTRY_DSN=

# API-Football (optional — live match data)
NEXT_PUBLIC_API_FOOTBALL_KEY=

# Supabase Admin (server-side only — for cron jobs and admin API routes)
SUPABASE_SERVICE_ROLE_KEY=

# Cron Secret (for Vercel Cron — generate with: openssl rand -hex 32)
CRON_SECRET=

# API-Football server-side key (same value as NEXT_PUBLIC_API_FOOTBALL_KEY)
API_FOOTBALL_KEY=

# League Configuration (optional — defaults to TFF 1. Lig 2024)
NEXT_PUBLIC_LEAGUE_ID=204
NEXT_PUBLIC_SEASON=2024

# Push Notifications (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Feature Flags
NEXT_PUBLIC_GEOFENCING_ENABLED=true
