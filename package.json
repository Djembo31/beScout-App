{
  "name": "bescout-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:smoke": "PLAYWRIGHT_BASE_URL=https://bescout.net playwright test --project=smoke --reporter=list",
    "test:synthetic": "PLAYWRIGHT_BASE_URL=https://bescout.net playwright test --project=synthetic --reporter=list",
    "test:fantasy-lifecycle": "PLAYWRIGHT_BASE_URL=https://bescout.net playwright test --project=fantasy-lifecycle --reporter=list",
    "audit": "bash scripts/audit/index.sh",
    "audit:compliance": "bash scripts/audit/compliance.sh",
    "audit:i18n": "node scripts/audit/i18n-coverage.js",
    "audit:rpc-security": "node scripts/audit/rpc-security.js",
    "audit:silent-fail": "npx tsx scripts/silent-fail-audit.ts",
    "audit:silent-fail:check": "npx tsx scripts/silent-fail-audit.ts --check",
    "audit:stale": "npx tsx scripts/audit-stale-check.ts",
    "audit:orphan": "npx tsx scripts/orphan-component-detector.ts",
    "audit:type-truth": "npx tsx scripts/type-truth-audit.ts",
    "audit:mutation-race": "bash scripts/audit-mutation-race.sh",
    "audit:mutation-race:check": "bash scripts/audit-mutation-race.sh --strict",
    "audit:wiring": "npx tsx scripts/wiring-check.ts",
    "audit:wiring:check": "npx tsx scripts/wiring-check.ts --check",
    "audit:cron-health": "npx tsx scripts/cron-health-check.ts",
    "audit:cron-health:check": "npx tsx scripts/cron-health-check.ts --check",
    "audit:tr-strings": "node scripts/audit/tr-strings.mjs",
    "rotate-secret": "npx tsx scripts/rotate-secret.ts",
    "beta:metrics": "node scripts/beta-metrics.mjs",
    "size": "npx tsx scripts/check-bundle-size.ts",
    "lighthouse:local": "lhci autorun --config=./lighthouserc.cjs",
    "cron:audit": "npx tsx scripts/check-cron-registry.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@sentry/nextjs": "^10.38.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/query-sync-storage-persister": "^5.100.6",
    "@tanstack/react-query": "^5.100.6",
    "@tanstack/react-query-persist-client": "^5.100.6",
    "country-flag-icons": "^1.6.15",
    "lucide-react": "^0.441.0",
    "next": "^14.2.35",
    "next-intl": "^4.8.3",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.58.2",
    "@tanstack/react-query-devtools": "^5.100.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "pg": "^8.18.0",
    "pino-pretty": "^13.1.3",
    "playwright": "1.58.2",
    "postcss": "^8.4.41",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^3.4.10",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
