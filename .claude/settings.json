{
  "version": "1.0",
  "permissions": {
    "Bash(*)": true,
    "Read(*)": true,
    "Write(*)": true,
    "Edit(*)": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/auto-lint.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/file-size-warning.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/test-reminder.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-post-service.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-stage-timer.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/track-file-changes.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/safety-guard.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/scripts/audit/pre-commit-guard.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-proof-gate.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-cto-review-gate.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-tool-wiring-gate.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-spec-gate.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-spec-quality-gate.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-meta-plan-block.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-parallel-dispatch-gate.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-ceo-scope-gate.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-task-enforcement.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/run_tests_on_change.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-status-gate.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-context7-gate.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-phase-gate.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/capture-correction.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/pre-compact-backup.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/inject-context-on-compact.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/session-handoff-auto.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-no-audit-slice.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-kanban-sync.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-phase-tracker-reminder.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/pattern-check.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/quality-gate-v2.sh"
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/session-retro.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/crash-recovery.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-session-start.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/ship-kanban-sync.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash C:/bescout-app/.claude/hooks/morning-briefing.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "settings": {}
}
